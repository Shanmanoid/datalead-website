# ===========================================
# DataLead Website — Environment Variables
# ===========================================
# This file documents all secrets/variables needed for deployment.
# Copy to .env and fill in actual values (never commit .env).

# --- GitHub Actions Secrets (CI/CD) ---
# These are configured in GitHub repo Settings > Secrets and variables > Actions

# VPS_HOST=your-vps-ip-address
# VPS_USER=deploy-user
# VPS_SSH_KEY=<private SSH key for VPS access>
# GHCR_TOKEN=<GitHub personal access token with packages:read scope>
# GHCR_USER=<GitHub username for container registry>

# --- Local Development ---
# No environment variables are required for local development.
# Just run: npm install && npm run dev
